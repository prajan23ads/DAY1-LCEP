<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Local Community Event Portal</title>

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap"
        rel="stylesheet">

    <!-- External CSS -->
    <link rel="stylesheet" href="styles2.css">

    <!-- Internal CSS -->
    <style>

        /* Internal CSS Example */
        body {
            background-color: #f0f4f7;
        }

    </style>

</head>

<body>

    <!-- Header Section -->
    <header id="mainHeader">

        <!-- Inline CSS Example -->
        <h1 style="color:red;">
            Local Community Event Portal
        </h1>

        <nav>
            <ul class="navMenu">
                <li><a href="#">Home</a></li>
                <li><a href="#">Events</a></li>
                <li><a href="#">Gallery</a></li>
                <li><a href="#">Contact</a></li>
            </ul>
        </nav>

    </header>

    <!-- Event Cards -->
    <section>

        <h2>Upcoming Events</h2>

        <div class="eventCard">

            <h3>Music Festival</h3>

            <p>
                Enjoy live performances, food stalls,
                and entertainment programs.
            </p>

            <button class="cta-button">
                Register Now
            </button>

        </div>

        <div class="eventCard hiddenBox">

            <h3>Sports Meet</h3>

            <p>
                Participate in exciting sports activities
                conducted by the city council.
            </p>

        </div>

        <div class="eventCard noneBox">

            <h3>Workshop</h3>

            <p>
                Learn web development and programming skills.
            </p>

        </div>

    </section>

    <!-- Table Section -->
    <section>

        <h2>Event Schedule</h2>

        <table>

            <tr>
                <th>Event</th>
                <th>Date</th>
                <th>Venue</th>
            </tr>

            <tr>
                <td>Music Festival</td>
                <td>10 June 2026</td>
                <td>City Hall</td>
            </tr>

            <tr>
                <td>Sports Meet</td>
                <td>15 June 2026</td>
                <td>Community Ground</td>
            </tr>

            <tr>
                <td>Workshop</td>
                <td>20 June 2026</td>
                <td>Library Hall</td>
            </tr>

        </table>

    </section>

    <!-- Multi Column News -->
    <section>

        <h2>Community Bulletin</h2>

        <div class="newsArticle">

            The city council has announced several
            new programs for residents. Free health
            camps, awareness programs, educational
            workshops, and environmental initiatives
            are planned this month. Residents are
            encouraged to actively participate in all
            events and help improve community welfare.

            Additional safety measures and volunteer
            programs are also being introduced for
            better public engagement.

        </div>

    </section>

    <!-- Form Section -->
    <section>

        <h2>Feedback Form</h2>

        <form>

            <input type="text"
                placeholder="Enter Name">

            <textarea placeholder="Enter Feedback"></textarea>

            <button type="submit">
                Submit
            </button>

        </form>

    </section>

</body>

</html>
